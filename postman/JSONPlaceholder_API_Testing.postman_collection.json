{
  "info": {
    "_postman_id": "dd5f5095-b8c2-465d-a440-5ad96a723f87",
    "name": "JSONPlaceholder API Testing - Postman",
    "description": "Bài thực hành kiểm thử REST API bằng Postman với JSONPlaceholder. Bao gồm CRUD, biến môi trường, test script và data-driven testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - CRUD Posts",
      "item": [
        {
          "name": "GET - Lấy danh sách bài viết",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code là 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Phản hồi là JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test(\"Danh sách có 100 bài viết\", function () {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data).to.be.an(\"array\");",
                  "    pm.expect(data.length).to.eql(100);",
                  "});",
                  "",
                  "pm.test(\"Bài viết đầu tiên có đủ trường dữ liệu\", function () {",
                  "    const firstPost = pm.response.json()[0];",
                  "    pm.expect(firstPost).to.have.all.keys(\"userId\", \"id\", \"title\", \"body\");",
                  "});",
                  "",
                  "pm.test(\"Thời gian phản hồi dưới 3000 ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts"
              ]
            },
            "description": "Lấy toàn bộ danh sách 100 bài viết."
          },
          "response": []
        },
        {
          "name": "GET - Lấy bài viết theo ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code là 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"ID trả về đúng với postId\", function () {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data.id).to.eql(Number(pm.environment.get(\"postId\")));",
                  "});",
                  "",
                  "pm.test(\"Response có đủ thuộc tính\", function () {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data).to.include.all.keys(\"userId\", \"id\", \"title\", \"body\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/{{postId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts",
                "{{postId}}"
              ]
            },
            "description": "Lấy chi tiết một bài viết bằng biến môi trường postId."
          },
          "response": []
        },
        {
          "name": "GET - Lọc bài viết theo userId",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code là 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Tất cả bài viết thuộc userId đã chọn\", function () {",
                  "    const data = pm.response.json();",
                  "    const expectedUserId = Number(pm.environment.get(\"userId\"));",
                  "    pm.expect(data).to.be.an(\"array\").that.is.not.empty;",
                  "    data.forEach(post => pm.expect(post.userId).to.eql(expectedUserId));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts?userId={{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts"
              ],
              "query": [
                {
                  "key": "userId",
                  "value": "{{userId}}"
                }
              ]
            },
            "description": "Kiểm thử query parameter userId."
          },
          "response": []
        },
        {
          "name": "POST - Tạo bài viết",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code là 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"API trả về ID mới\", function () {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data.id).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Dữ liệu trả về khớp dữ liệu gửi lên\", function () {",
                  "    const requestBody = JSON.parse(pm.request.body.raw);",
                  "    const responseBody = pm.response.json();",
                  "    pm.expect(responseBody.title).to.eql(requestBody.title);",
                  "    pm.expect(responseBody.body).to.eql(requestBody.body);",
                  "    pm.expect(responseBody.userId).to.eql(requestBody.userId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Bài thực hành Postman\",\n  \"body\": \"Kiểm thử API bằng phương thức POST\",\n  \"userId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts"
              ]
            },
            "description": "Tạo mới một bài viết giả lập."
          },
          "response": []
        },
        {
          "name": "PUT - Cập nhật toàn bộ bài viết",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code là 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Thông tin cập nhật đúng\", function () {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data.id).to.eql(Number(pm.environment.get(\"postId\")));",
                  "    pm.expect(data.title).to.eql(\"Cập nhật toàn bộ bằng PUT\");",
                  "    pm.expect(data.body).to.eql(\"Nội dung đã được thay thế\");",
                  "    pm.expect(data.userId).to.eql(1);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 1,\n  \"title\": \"Cập nhật toàn bộ bằng PUT\",\n  \"body\": \"Nội dung đã được thay thế\",\n  \"userId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/posts/{{postId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts",
                "{{postId}}"
              ]
            },
            "description": "Cập nhật toàn bộ dữ liệu bài viết."
          },
          "response": []
        },
        {
          "name": "PATCH - Cập nhật một phần bài viết",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code là 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Trường title đã được cập nhật\", function () {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data.title).to.eql(\"Cập nhật một phần bằng PATCH\");",
                  "    pm.expect(data.id).to.eql(Number(pm.environment.get(\"postId\")));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Cập nhật một phần bằng PATCH\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/posts/{{postId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts",
                "{{postId}}"
              ]
            },
            "description": "Chỉ cập nhật trường title."
          },
          "response": []
        },
        {
          "name": "DELETE - Xóa bài viết",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code là 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response trả về object rỗng\", function () {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data).to.be.an(\"object\");",
                  "    pm.expect(Object.keys(data).length).to.eql(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/{{postId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts",
                "{{postId}}"
              ]
            },
            "description": "Xóa một bài viết giả lập."
          },
          "response": []
        }
      ]
    },
    {
      "name": "02 - Data-driven Testing",
      "item": [
        {
          "name": "GET - Kiểm thử người dùng theo dữ liệu",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code là 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Tên người dùng đúng với dữ liệu kiểm thử\", function () {",
                  "    const data = pm.response.json();",
                  "    const expectedName = pm.iterationData.get(\"expectedName\") || pm.environment.get(\"expectedName\");",
                  "    pm.expect(data.name).to.eql(expectedName);",
                  "});",
                  "",
                  "pm.test(\"Email có định dạng hợp lệ\", function () {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data.email).to.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            },
            "description": "Chạy bằng Collection Runner và file data/users.json."
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Ghi lại thời điểm bắt đầu request để phục vụ kiểm thử.",
          "pm.variables.set(\"requestStartedAt\", Date.now());"
        ]
      }
    }
  ],
  "variable": []
}